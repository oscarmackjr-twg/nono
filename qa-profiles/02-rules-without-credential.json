{
    "meta": { "name": "qa-rules-without-credential" },
    "filesystem": { "allow": ["."] },
    "network": {
        "allow_domain": ["example.com"],
        "credentials": ["httpbin"],
        "custom_credentials": {
            "httpbin": {
                "upstream": "https://httpbin.org",
                "credential_key": "httpbin_dummy_unused",
                "env_var": "HTTPBIN_API_KEY",
                "endpoint_rules": [
                    { "method": "GET", "path": "/get" },
                    { "method": "GET", "path": "/ip" }
                ]
            }
        }
    }
}
